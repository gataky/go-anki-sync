# Example environment variables for Anki-Sheets Sync
# Copy this file to .env if you want to use environment variables
# Note: The tool primarily uses ~/.sync/config.yaml for configuration

# Anki Configuration
# ANKI_CONNECT_URL=http://localhost:8765
# ANKI_DECK=Greek

# Google Sheets Configuration
# GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms
# SHEET_NAME=Sheet1

# Logging
# LOG_LEVEL=info

# File Paths (optional - defaults shown)
# CONFIG_PATH=~/.sync/config.yaml
# STATE_PATH=~/.sync/state.json
# CREDENTIALS_PATH=~/.sync/credentials.json
# TOKEN_PATH=~/.sync/token.json
